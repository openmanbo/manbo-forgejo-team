{
  "mcpServers": {
    "tavily": {
      "command": "npx",
      "args": [
        "-y",
        "tavily-mcp"
      ]
    },
    "forgejo": {
      "command": "npx",
      "args": [
        "-y",
        "@openmanbo/forgejo-mcp"
      ],
      "env": {
        "FORGEJO_URL": "${FORGEJO_URL}",
        "FORGEJO_TOKEN": "${FORGEJO_TOKEN}"
      }
    },
    "lsp": {
      "command": "npx",
      "args": [
        "-y",
        "lsp-mcp-server"
      ]
    }
  }
}
